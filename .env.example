# Copy this to .env.local and fill in your keys
# NEVER commit .env.local to GitHub

# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Get from: https://dashboard.privy.io → your app → API keys
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Get from: https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# Local dev URL (change to Vercel URL after deploy)
NEXT_PUBLIC_APP_URL=http://localhost:3000
